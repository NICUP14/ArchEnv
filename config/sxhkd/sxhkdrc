# Volume keys
XF86AudioLowerVolume
    ~/.local/scripts/dec_volume.sh

XF86AudioRaiseVolume
    ~/.local/scripts/inc_volume.sh

XF86AudioMute
    ~/.local/scripts/toggle_volume.sh

XF86AudioMicMute
    ~/.local/scripts/toggle_mic.sh

# Toggle touchpad
alt + shift + space
    ~/.local/scripts/toggle_touchpad.sh

# Take full screenshot
Print
    /usr/bin/flameshot full

# Take custom screenshot
shift + Print
    /usr/bin/flameshot gui

